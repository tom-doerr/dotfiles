#!/usr/bin/env python3
"""Generate a sparse OLED-friendly lock image and launch swaylock."""

from __future__ import annotations

import argparse
import json
import os
import random
import subprocess
from pathlib import Path

from PIL import Image, ImageDraw


PALETTE = [
    (0, 255, 255),
    (0, 255, 120),
    (60, 120, 255),
    (180, 60, 255),
    (255, 0, 180),
    (255, 60, 60),
    (255, 220, 0),
]


def parse_geometry(value: str) -> tuple[int, int]:
    width, height = value.lower().split("x", 1)
    return int(width), int(height)


def monitor_geometry() -> tuple[int, int]:
    override = os.environ.get("OLED_LOCK_GEOMETRY")
    if override:
        return parse_geometry(override)

    monitors = json.loads(subprocess.check_output(["hyprctl", "monitors", "-j"], text=True))
    widths = [int(m["width"]) for m in monitors]
    heights = [int(m["height"]) for m in monitors]
    return max(widths), max(heights)


def render(path: Path, width: int, height: int) -> None:
    rng = random.SystemRandom()
    image = Image.new("RGB", (width, height), (0, 0, 0))
    draw = ImageDraw.Draw(image)

    dot_count = max(80, min(520, (width * height) // 18000))
    for _ in range(dot_count):
        x = rng.randrange(width)
        y = rng.randrange(height)
        color = rng.choice(PALETTE)
        radius = rng.choice((1, 1, 1, 2))
        draw.rectangle((x - radius, y - radius, x + radius, y + radius), fill=color)

    for _ in range(max(4, dot_count // 80)):
        x = rng.randrange(width)
        y = rng.randrange(height)
        color = rng.choice(PALETTE)
        draw.line((x - 5, y, x + 5, y), fill=color)
        draw.line((x, y - 5, x, y + 5), fill=color)

    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(".tmp.png")
    image.save(tmp)
    tmp.replace(path)


def lock_image_path() -> Path:
    configured = os.environ.get("OLED_LOCK_OUTPUT")
    if configured:
        return Path(configured)
    return Path(f"/run/user/{os.getuid()}/oled-lock.png")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--render-only", action="store_true")
    args = parser.parse_args()

    path = lock_image_path()
    width, height = monitor_geometry()
    render(path, width, height)

    if args.render_only:
        print(path)
        return 0

    if subprocess.run(["pidof", "swaylock"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0:
        return 0

    os.execvp(
        "swaylock",
        [
            "swaylock",
            "-f",
            "-c",
            "000000",
            "-i",
            str(path),
            "-s",
            "center",
            "--indicator-radius",
            "120",
            "--indicator-thickness",
            "8",
            "--inside-color",
            "000000dd",
            "--ring-color",
            "33ccffee",
            "--key-hl-color",
            "00ff99ee",
            "--bs-hl-color",
            "ff4d6dee",
            "--text-color",
            "e8f5f8ff",
            "--line-color",
            "00000000",
            "--separator-color",
            "00000000",
        ],
    )


if __name__ == "__main__":
    raise SystemExit(main())
